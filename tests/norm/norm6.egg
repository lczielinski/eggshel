(let ex (Base 0.0 (Sqrt (Add (Mul (Var "x") (Var "x")) (Add (Mul (Var "y") (Var "y")) (Add (Mul (Var "z") (Var "z")) (Add (Mul (Var "a") (Var "a")) (Add (Mul (Var "b") (Var "b")) (Mul (Var "c") (Var "c")))))))) 0.0))

(rule ((Base 0.0 (Var "x") x_p) (Base 0.0 (Var "y") y_p) (Base 0.0 (Var "z") z_p) (Base 0.0 (Var "a") a_p) (Base 0.0 (Var "b") b_p) (Base 0.0 (Var "c") c_p))
      ((Tens (Base 0.0 (Var "x") x_p) (Tens (Base 0.0 (Var "y") y_p) (Tens (Base 0.0 (Var "z") z_p) (Tens (Base 0.0 (Var "a") a_p) (Tens (Base 0.0 (Var "b") b_p) (Base 0.0 (Var "c") c_p))))))))

(ruleset trans)

(rule ((-> ctx2 ex) (-> ctx1 ctx2))
      ((-> ctx1 ex)) :ruleset trans)

(relation bounds (String f64 String f64 String f64 String f64 String f64 String f64))

(ruleset post)

(rule ((-> (Tens (Base 0.0 (Var "x") x_p) (Tens (Base 0.0 (Var "y") y_p) (Tens (Base 0.0 (Var "z") z_p) (Tens (Base 0.0 (Var "a") a_p) (Tens (Base 0.0 (Var "b") b_p) (Base 0.0 (Var "c") c_p)))))) ex))
      ((bounds "x" x_p "y" y_p "z" z_p "a" a_p "b" b_p "c" c_p)) :ruleset post)

(run-schedule (seq (saturate (seq (run) (run trans))) (run post)))

(print-function bounds 10)

