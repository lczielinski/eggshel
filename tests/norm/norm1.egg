(let ex (Base 0.0 (Sqrt (Mul (Var "x") (Var "x"))) 0.0))

(rule ((Base 0.0 (Var "x") x_p))
      ((Base 0.0 (Var "x") x_p)))

(ruleset trans)

(rule ((-> ctx2 ex) (-> ctx1 ctx2))
      ((-> ctx1 ex)) :ruleset trans)

(relation bounds (String f64))

(ruleset post)

(rule ((-> (Base 0.0 (Var "x") x_p) ex))
      ((bounds "x" x_p)) :ruleset post)

(run-schedule (seq (saturate (seq (run) (run trans))) (run post)))

(print-function bounds 10)

