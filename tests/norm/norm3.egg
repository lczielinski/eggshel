(let ex (Base 0.0 (Sqrt (Add (Mul (Var "x") (Var "x")) (Add (Mul (Var "y") (Var "y")) (Mul (Var "z") (Var "z"))))) 0.0))

(rule ((Base 0.0 (Var "x") x_p) (Base 0.0 (Var "y") y_p) (Base 0.0 (Var "z") z_p))
      ((Tens (Base 0.0 (Var "x") x_p) (Tens (Base 0.0 (Var "y") y_p) (Base 0.0 (Var "z") z_p)))))

(run-schedule (saturate (run)))

(relation bounds (String f64 String f64 String f64))

(rule ((-> (Tens (Base 0.0 (Var "x") ?x_p) (Tens (Base 0.0 (Var "y") ?y_p) (Base 0.0 (Var "z") ?z_p))) ex))
      ((bounds "x" ?x_p "y" ?y_p "z" ?z_p)))

(run 1)

(print-function bounds 10)

