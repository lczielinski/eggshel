(let ex (Base 0.0 (Add (Var "x") (Mul (Var "x") (Mul (Var "x") (Var "a")))) 0.0))

(rule ((Base 0.0 (Var "x") x_p) (Base 0.0 (Var "a") a_p))
      ((Tens (Base 0.0 (Var "x") x_p) (Base 0.0 (Var "a") a_p))))

(run-schedule (saturate (run)))

(relation bounds (String f64 String f64))

(rule ((-> (Tens (Base 0.0 (Var "x") ?x_p) (Base 0.0 (Var "a") ?a_p)) ex))
      ((bounds "x" ?x_p "a" ?a_p)))

(run 1)

(print-function bounds 10)

; [INFO ]    (bounds "x" 1.0 "a" 1.0)

; Took 0.04715058300644159 seconds