(let ex (Base 0.0 (Sqrt (Add (Mul (Var "a") (Var "x")) (Sqrt (Var "b")))) 0.0))

(rule ((Base 0.0 (Var "a") a_p) (Base 0.0 (Var "x") x_p) (Base 0.0 (Var "b") b_p))
      ((Tens (Base 0.0 (Var "a") a_p) (Tens (Base 0.0 (Var "x") x_p) (Base 0.0 (Var "b") b_p)))))

(rule ((-> ctx2 ex) (-> ctx1 ctx2))
      ((-> ctx1 ex)))

(run-schedule (saturate (run)))

(ruleset post)

(relation bounds (String f64 String f64 String f64))

(rule ((-> (Tens (Base 0.0 (Var "a") a_p) (Tens (Base 0.0 (Var "x") x_p) (Base 0.0 (Var "b") b_p))) ex))
      ((bounds "a" a_p "x" x_p "b" b_p)) :ruleset post)

(run post 1)

(print-function bounds 10)

