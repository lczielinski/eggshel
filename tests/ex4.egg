(let ex (Base 0.0 (Mul (Add (Var "a") (Mul (Var "a") (Var "b"))) (Add (Var "c") (Mul (Var "c") (Var "d")))) 0.0))

(rule ((Base 0.0 (Var "a") a_p) (Base 0.0 (Var "b") b_p) (Base 0.0 (Var "c") c_p) (Base 0.0 (Var "d") d_p))
      ((Tens (Base 0.0 (Var "a") a_p) (Tens (Base 0.0 (Var "b") b_p) (Tens (Base 0.0 (Var "c") c_p) (Base 0.0 (Var "d") d_p))))))

(rule ((-> ctx2 ex) (-> ctx1 ctx2))
      ((-> ctx1 ex)))

(run-schedule (saturate (run)))

(ruleset post)

(relation bounds (String f64 String f64 String f64 String f64))

(rule ((-> (Tens (Base 0.0 (Var "a") a_p) (Tens (Base 0.0 (Var "b") b_p) (Tens (Base 0.0 (Var "c") c_p) (Base 0.0 (Var "d") d_p)))) ex))
      ((bounds "a" a_p "b" b_p "c" c_p "d" d_p)) :ruleset post)

(run post 1)

(print-function bounds 10)

