(let _ex (Ctx (set-of (Leaf (Par (Add (Var "a") (Sqrt (Mul (Var "a") (Var "b")))) 0.0)))))

(run-schedule (saturate (run)))

(relation bounds (String f64 String f64))

(rule ((-> (Ctx (set-of (Leaf (Par (Var "a") ?a_p)) (Leaf (Par (Var "b") ?b_p)))) _ex))
      ((bounds "a" ?a_p "b" ?b_p)))

(run 1)

(print-function bounds 10)

(query-extract (Ctx c))

