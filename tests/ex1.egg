(let ex (Base 0.0 (Add (Var "x") (Add (Mul (Var "a") (Var "x")) (Mul (Mul (Var "b") (Var "x")) (Var "x")))) 0.0))

(rule ((Base 0.0 (Var "a") a_p) (Base 0.0 (Var "b") b_p) (Base 0.0 (Var "x") x_p))
      ((Tens (Base 0.0 (Var "a") a_p) (Tens (Base 0.0 (Var "b") b_p) (Base 0.0 (Var "x") x_p)))))

(rule ((-> b ex) (-> a b))
    ((-> a ex)))

(run-schedule (saturate (run)))

(relation bounds (String f64 String f64 String f64))

(ruleset get-bounds)

(rule ((-> (Tens (Base 0.0 (Var "a") ?a_p) (Tens (Base 0.0 (Var "b") ?b_p) (Base 0.0 (Var "x") ?x_p))) ex))
      ((bounds "a" ?a_p "b" ?b_p "x" ?x_p)) :ruleset get-bounds)

(run-schedule (repeat 1 get-bounds))

(print-function bounds 10)

