(let _ex (Ctx (set-of (Leaf (Par (Add (Var "x") (Add (Mul (Var "a") (Var "x")) (Mul (Mul (Var "b") (Var "x")) (Var "x")))) 0.0)))))

; (run-schedule (saturate (run)))
(run 6)
(query-extract (Ctx c))

(relation bounds (String f64 String f64 String f64))

(rule ((-> (Ctx (set-of (Leaf (Par (Var "a") ?a_p)) (Leaf (Par (Var "b") ?b_p)) (Leaf (Par (Var "x") ?x_p)))) _ex))
      ((bounds "a" ?a_p "b" ?b_p "x" ?x_p)))

(run 1)

(print-function bounds 10)

