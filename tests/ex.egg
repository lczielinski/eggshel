(run-schedule (saturate (run)))
; (run 5)
(relation bounds (String f64 String f64 String f64))
(query-extract (Ctx c))

(rule ((-> (Ctx (set-of (Leaf (Par (Var "a") ?a_p)) (Leaf (Par (Var "x") ?x_p)) (Leaf (Par (Var "b") ?b_p)))) _ex))
      ((bounds "a" ?a_p "x" ?x_p "b" ?b_p)))
(run 1)

(print-function bounds 10)
