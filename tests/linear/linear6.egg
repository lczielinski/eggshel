(let ex (Base 0.0 (Add (Var "x") (Add (Mul (Var "a") (Var "x")) (Add (Mul (Var "b") (Var "x")) (Add (Mul (Var "c") (Var "x")) (Add (Mul (Var "d") (Var "x")) (Mul (Var "e") (Var "x"))))))) 0.0))

(rule ((Base 0.0 (Var "x") x_p) (Base 0.0 (Var "a") a_p) (Base 0.0 (Var "b") b_p) (Base 0.0 (Var "c") c_p) (Base 0.0 (Var "d") d_p) (Base 0.0 (Var "e") e_p))
      ((Tens (Base 0.0 (Var "x") x_p) (Tens (Base 0.0 (Var "a") a_p) (Tens (Base 0.0 (Var "b") b_p) (Tens (Base 0.0 (Var "c") c_p) (Tens (Base 0.0 (Var "d") d_p) (Base 0.0 (Var "e") e_p))))))))

