(let ex (Base 0.0 (Add (Var "x") (Add (Mul (Var "a") (Var "x")) (Mul (Var "b") (Var "x")))) 0.0))

(rule ((Base 0.0 (Var "x") x_p) (Base 0.0 (Var "a") a_p) (Base 0.0 (Var "b") b_p))
      ((Tens (Base 0.0 (Var "x") x_p) (Tens (Base 0.0 (Var "a") a_p) (Base 0.0 (Var "b") b_p)))))

(run-schedule (saturate (run)))

(relation bounds (String f64 String f64 String f64))

(rule ((-> (Tens (Base 0.0 (Var "x") ?x_p) (Tens (Base 0.0 (Var "a") ?a_p) (Base 0.0 (Var "b") ?b_p))) ex))
      ((bounds "x" ?x_p "a" ?a_p "b" ?b_p)))

(run 1)

(print-function bounds 10)

