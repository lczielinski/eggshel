; if -> X Y f, then f : X -> Y is a morphism
(relation -> (Ob Ob Expr))

; composition
(rule ((-> X Y f) (-> Y Z g))
    ((-> X Z (Compose f g))))

; tensor congruence right
(rule ((-> X Y f)
       (= e (Star X 0.0 Z))
       (= nX (dim X))
       (= nZ (dim Z)))
    ((-> e (Star Y 0.0 Z) (Pair f (Shift (Id nZ) nX)))))

; tensor congruence left
(rule ((-> X Y f)
       (= e (Star Z 0.0 X))
       (= nZ (dim Z)))
    ((-> e (Star Z 0.0 Y) (Pair (Id nZ) (Shift f nZ)))))

; star congruence

; tensor symmetry
(rule ((= e (Star X 0.0 Y))
       (= nX (dim X))
       (= nY (dim Y)))
    ((-> e (Star Y 0.0 X) (Pair (Shift (Id nY) nX) (Id nX)))))

; projections
(rule ((= e (Star X i Y))
       (= nX (dim X))
       (= nY (dim Y)))
    ((-> e X (Id nX))
     (-> e Y (Shift (Id nY) nX))))

; combiner
(rule ((= e (Star (Base n1 p1) i (Base n2 p2)))
       (= p2 (* p1 (abs (- i 1.0))))
       (= sum (+ n1 n2)))
    ((-> e (Base sum p1) (Id sum))))

; add
(rule ((= e (Base 2 p))
       (>= p 1.0)
       (= q (- p 1.0)))
    ((-> e (Base 1 q) (Add (Var 1) (Var 2)))))

; mul
(rule ((= e (Base 2 p))
       (>= p 0.5)
       (= q (- (* p 2.0) 1.0)))
    ((-> e (Base 1 q) (Mul (Var 1) (Var 2)))))

; dmul
(rule ((= e (Star ob1 i ob2))
       (= ob1 (Base 1 p1))
       (= ob2 (Base 1 p2))
       (>= p2 1.0)
       (= q (- p2 1.0))
       (= j (+ i 1.0)))
    ((-> e (Star ob1 j (Base 1 q)) (Mul (Var 1) (Var 2)))))

; (a_p1 (x)_i b) (x) c_p+p2 --> a_p1 (x)_i (b (x) c_p2)
(rule ((= e (Star (Star ob1 i ob2) 0.0 ob3))
       (= ob1 (Base n1 p1))
       (= dim2 (dim ob2))
       (= ob3 (Base n3 p3))
       (= p (* i p1))
       (>= p3 p)
       (= id (Id (+ n1 (+ dim2 n3)))))
    ((-> e (Star ob1 i (Star ob2 0.0 (Base n3  p3))) id)))

(let _a0 (Base 1 0.0))
(let _a05 (Base 1 0.5))
(let _a1 (Base 1 1.0))
(let _a2 (Base 1 2.0))
(let _ab0 (Base 2 0.0))
(let _ab1 (Base 2 1.0))
(let _ab2 (Base 2 2.0))

; (let _ex1 (Star (Star _a2 0.0 _a2) 0.0 _a0))
(let _ex2 (Star (Star _a2 0.0 _a2) 0.0 _a1))

