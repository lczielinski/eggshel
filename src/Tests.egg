(let _a (Var "a"))
(let _b (Var "b"))
(let _c (Var "c"))
(let _d (Var "d"))
(let _e (Var "e"))

(let _a05 (Base 0.0 _a 0.5))
(let _a1 (Base 0.0 _a 1.0))
(let _a15 (Base 0.0 _a 1.5))
(let _a2 (Base 0.0 _a 2.0))
(let _a3 (Base 0.0 _a 3.0))
(let _b1 (Base 0.0 _b 1.0))
(let _b15 (Base 0.0 _b 1.5))
(let _b2 (Base 0.0 _b 2.0))
(let _b3 (Base 0.0 _b 3.0))
(let _c1 (Base 0.0 _c 1.0))
(let _c2 (Base 0.0 _c 2.0))
(let _c3 (Base 0.0 _c 3.0))
(let _c4 (Base 0.0 _c 4.0))
(let _d1 (Base 0.0 (Var "d") 1.0))
(let _d2 (Base 0.0 (Var "d") 2.0))
(let _d3 (Base 0.0 (Var "d") 3.0))
(let _e1 (Base 0.0 (Var "e") 1.0))
