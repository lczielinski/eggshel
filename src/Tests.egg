(let _a1 (Base 0.0 (Var "a") 1.0))
(let _a2 (Base 0.0 (Var "a") 2.0))
(let _a3 (Base 0.0 (Var "a") 3.0))
(let _b1 (Base 0.0 (Var "b") 1.0))
(let _b2 (Base 0.0 (Var "b") 2.0))
(let _b3 (Base 0.0 (Var "b") 3.0))
(let _c1 (Base 0.0 (Var "c") 1.0))
(let _c2 (Base 0.0 (Var "c") 2.0))
(let _c3 (Base 0.0 (Var "c") 3.0))
(let _d1 (Base 0.0 (Var "d") 1.0))
(let _d2 (Base 0.0 (Var "d") 2.0))
(let _d3 (Base 0.0 (Var "d") 3.0))
(let _e1 (Base 0.0 (Var "e") 1.0))
(let _e2 (Base 0.0 (Var "e") 2.0))
(let _e3 (Base 0.0 (Var "e") 3.0))

(let _ex1 (Base 0.0 (Mul (Add (Var "a") (Mul (Var "a") (Var "b"))) (Var "c")) 0.0))
(let _ctx1 (Tens _a1 (Tens _b1 _c1)))

(run-schedule (saturate (run)))
(check (<- _ex1 _ctx1))

