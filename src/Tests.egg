(let _a (Var "a"))
(let _b (Var "b"))
(let _c (Var "c"))
(let _d (Var "d"))
(let _e (Var "e"))

(let _a05 (Base 0.0 _a 0.5))
(let _a1 (Base 0.0 _a 1.0))
(let _a15 (Base 0.0 _a 1.5))
(let _a2 (Base 0.0 _a 2.0))
(let _a3 (Base 0.0 _a 3.0))
(let _b1 (Base 0.0 _b 1.0))
(let _b15 (Base 0.0 _b 1.5))
(let _b2 (Base 0.0 _b 2.0))
(let _b3 (Base 0.0 _b 3.0))
(let _b4 (Base 0.0 _b 4.0))
(let _c1 (Base 0.0 _c 1.0))
(let _c15 (Base 0.0 _c 1.5))
(let _c2 (Base 0.0 _c 2.0))
(let _c3 (Base 0.0 _c 3.0))
(let _c4 (Base 0.0 _c 4.0))
(let _d1 (Base 0.0 _d 1.0))
(let _d2 (Base 0.0 _d 2.0))
(let _d25 (Base 0.0 _d 2.5))
(let _d3 (Base 0.0 _d 3.0))
(let _e1 (Base 0.0 _e 1.0))
(let _e2 (Base 0.0 _e 2.0))
(let _e25 (Base 0.0 _e 2.5))
(let _e3 (Base 0.0 _e 3.0))
(let _const (Base 0.0 (Var "1") 0.0))


(let _ex1 (Base 0.0 (Mul (Add _a (Mul _a _b)) _c) 0.0))
(let _ctx1 (Tens _a1 (Tens _b1 _c1)))

(let _ex2 (Base 0.0 (Add (Mul _a _a) (Mul _b _b)) 0.0))
(let _ctx2 (Tens _a1 _b1))

(let _ex3 (Base 0.0 (Add (Add (Mul _a _b) (Mul (Mul _a _c) _a)) _a) 0.0))
(let _ctx3 (Tens _a1 (Tens _b2 _c4)))

(let _ex4 (Base 0.0 (Add _a (Add _b (Mul _c (Add _d _e)))) 0.0))
(let _ctx4 (Tens _a1 (Tens _b2 (Tens _c15 (Tens _d25 _e25)))))

(let _ex5 (Base 0.0 (Add _a (Sqrt (Mul _a _b))) 0.0))
(let _ctx5 (Tens _a1 _b4))

(let _ex6 (Base 0.0 (Sqrt (Add (Var "a") (Var "b"))) 0.0))
(let _ctx6 (Base 0.0 (Add (Var "a") (Var "b")) 2.0))

(let _ex7 (Base 0.0 (Add _a (Mul _a _b)) 0.0))
(let _ctx7 (Tens _a1 _b1))

(let _ex8 (Base 0.0 (Add _a (Mul _a (Mul _a _b))) 0.0))
(let _ctx8 (Tens _a1 _b3))

(run-schedule (saturate (run)))
(check (-> _ctx1 _ex1))
(check (-> _ctx2 _ex2))
(check (-> _ctx3 _ex3))
(check (-> _ctx4 _ex4))
(check (-> _ctx5 _ex5))
(check (-> _ctx6 _ex6))
(check (-> _ctx7 _ex7))
(check (-> _ctx8 _ex8))
